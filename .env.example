# Safe first run: make one request and never place orders.
BOR_MODE=live_once
BOR_RELEASE_DATE=24.07.2026
BOR_RELEASE_TIME_SUFFIX=133000key_e
BOR_POLL_SLEEP_SEC=0.25
BOR_HEARTBEAT_SEC=10
BOR_CONNECT_TIMEOUT_SEC=0.5
BOR_READ_TIMEOUT_SEC=0.5
BOR_PREFIX_MAX_BYTES=32768
BOR_PREFIX_CHUNK_SIZE=2048
BOR_DISABLE_CACHE_BUSTER=0

LOG_LEVEL=INFO
CBR_DRY_RUN=1
# Required to calculate the change in basis points and evaluate rules.
BOR_PREV_RATE=

# Telegram is opt-in. Keep disabled until both values below are configured.
CBR_TELEGRAM_ENABLED=0
TG_BOT_TOKEN=
TELEGRAM_INGEST_CHAT_ID=
TG_HTTP_TIMEOUT=10
