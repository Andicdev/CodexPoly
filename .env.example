# Safe first run: make one request and never place orders.
BOR_MODE=live_once
BOR_RELEASE_DATE=24.07.2026
BOR_RELEASE_TIME_SUFFIX=133000key_e
BOR_POLL_SLEEP_SEC=0.25
BOR_HEARTBEAT_SEC=10
BOR_CONNECT_TIMEOUT_SEC=0.5
BOR_READ_TIMEOUT_SEC=0.5
BOR_PREFIX_MAX_BYTES=32768
BOR_PREFIX_CHUNK_SIZE=2048
BOR_DISABLE_CACHE_BUSTER=0

LOG_LEVEL=INFO
CBR_DRY_RUN=1
# Required to calculate the change in basis points and evaluate rules.
BOR_PREV_RATE=

# Database routing. CBR_ON_RENDER overrides the legacy SERVER flag.
# Render: CBR_ON_RENDER=1 -> server_int.
# Local machine or VPS: CBR_ON_RENDER=0 -> server_ext.
CBR_ON_RENDER=0
PRIMARY_DB_TARGET=
ANALYTICS_DB_TARGET=
DATABASE_URL_LOCAL=
DATABASE_URL_SERVER_INT=
DATABASE_URL_SERVER_EXT=
ANALYTICS_DATABASE_URL_LOCAL=
ANALYTICS_DATABASE_URL_SERVER_INT=
ANALYTICS_DATABASE_URL_SERVER_EXT=

# Optional direct URL overrides for each role.
CBR_DATABASE_URL=
CBR_ANALYTICS_DATABASE_URL=

# Optional read-only preload of active CBR rules from the primary DB.
CBR_RULES_DB_ENABLED=0

# Separate write access used only by `python -m cbr_trading.admin --apply`.
# When empty, the selected primary URL above is used.
CBR_ADMIN_DATABASE_URL=
CBR_ACCOUNT_NAME_FAST=
CBR_ORDER_QTY=10
CBR_ORDER_PRICE_YES=0.99
CBR_ORDER_PRICE_NO=0.99
CBR_ORDER_PRICE_YES_INCREASE=
CBR_ORDER_PRICE_NO_INCREASE=
CBR_TG_CHAT_ID=
CBR_GAMMA_TIMEOUT_SEC=10

# Telegram is opt-in. Keep disabled until both values below are configured.
CBR_TELEGRAM_ENABLED=0
TG_BOT_TOKEN=
TELEGRAM_INGEST_CHAT_ID=
TG_HTTP_TIMEOUT=10
